{
  "name": "{{APP_NAME_SNAKE}}",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run migrate:db && NODE_ENV=production bun run src/index.ts",
    "fmt": "prettier --write .",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --ext .js,.ts --fix",
    "purge:db": "docker compose down -v",
    "wake:db": "docker compose up -d",
    "down:db": "docker compose down",
    "push:db": "bunx drizzle-kit push",
    "migrate:db": "bunx drizzle-kit migrate",
    "generate:migrations": "bunx drizzle-kit generate",
    "init:env": "cp ./.env.example ./.env",
    "init:all": "bun init:env && bun install && bun wake:db && bun migrate:db"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.0",
    "globals": "^17.0.0",
    "prettier": "3.7.4",
    "typescript-eslint": "^8.51.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.5.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "class-validator-jsonschema": "^5.1.0",
    "dotenv": "^17.2.0",
    "dotenv-expand": "^12.0.0",
    "drizzle-orm": "^0.45.0",
    "hono": "4.9.9",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2"
  }
}
